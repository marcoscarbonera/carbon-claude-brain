# carbon-claude-brain configuration
#
# USO:
#   1. Para modo não-interativo: Copie este arquivo para a raiz do plugin como .env
#      e preencha os valores. Execute: bash configure.sh
#   2. Para modo interativo: Execute: bash configure.sh (sem criar .env)
#
# DO NOT COMMIT THIS FILE

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Obsidian Configuration (OBRIGATÓRIO)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Caminho completo para o vault do Obsidian
# Dica: Obsidian → Settings → Files & Links → Vault location
OBSIDIAN_VAULT="/Users/yourname/Documents/MyVault"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Inkdrop Configuration (OPCIONAL)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Para desabilitar Inkdrop: deixe INKDROP_URL vazio
# Para habilitar: preencha URL, USER e PASS

# URL da API local do Inkdrop (padrão: http://localhost:19840)
INKDROP_URL="http://localhost:19840"

# Credenciais do plugin local-rest-api
# IMPORTANTE: Use senha diferente da conta Inkdrop Cloud
INKDROP_USER="your_username"
INKDROP_PASS="your_password"

# ID do notebook de destino (opcional)
# Use /brain-inkdrop-setup para listar notebooks disponíveis
# Deixe vazio para usar o inbox
INKDROP_NOTEBOOK_ID=""

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Exemplo: Apenas Obsidian (sem Inkdrop)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OBSIDIAN_VAULT="/Users/yourname/Documents/MyVault"
# INKDROP_URL=""
# INKDROP_USER=""
# INKDROP_PASS=""
# INKDROP_NOTEBOOK_ID=""
